{% capture formName %}
 {% if formName and formName != "" %}
  {{formName}} 
 {% else %}
 {{page.url}}
 {% endif %} 
{% endcapture %}
<div class="c-formBuilder w-full flex flex-col justify-center items-center">
  <form
    {% if successPage %}
    action="{{ successPage }}"
    {% endif %}
    method="POST"
    data-netlify="true"
    data-netlify-recaptcha="true"
    netlify-honeypot="_gotcha"
    name="{{ formName | strip }}"
    class="w-full max-w-[512px]">

    {% if sectionId %}
      {% bookshop "util/IdScrollEvent" sectionId: sectionId %}
    {% endif %}
    {% for element in form_elements %}
      <div class="mt-4">{% bookshop "{{element._bookshop_name}}" bind: element %}</div>
    {% endfor %}
    {% comment %} Honeypot {% endcomment %}
    <p style="display: none">
      <label>Maiden Name:<input name="_gotcha"></label>
    </p>
    {% if subject and subject != "" %}
      {% if site.config.host == "cloudcannon" %}
        <input
          type="hidden"
          name="inbox_key"
          value="{{inboxKey}}">
        <input
          type="hidden"
          name="_subject"
          value="{{subject}}" />
      {% elsif site.config.host == "netlify" %}
        <input
          type="hidden"
          name="subject"
          value="{{subject}}" />
      {% endif %}
    {% endif %}
    <div class="mt-4" data-netlify-recaptcha="true"></div>
    <div class="mt-5 flex justify-end">{% bookshop "generic/button" bind: submitButton %}</div>
    <div class="flex justify-center">
      <ul class="underline text-sm flex flex-wrap overflow-hidden gap-x-4 gap-y-1 ">
        {% if site.termsAndConditionsUrl and site.termsAndConditionsUrl != "" %}
          <li class="hover:underline after:absolute after:content-['|'] after:scale-150 relative before:content-[' '] after:left-[-11px] after:text-lg">
            <a
              data-umami-event="TermsAndConditions-footer"
              href="{{ site.termsAndConditionsUrl }}"
              target="_blank">Terms & Conditions</a>
          </li>
        {% endif %}
        {% if site.privacyPolicyUrl and site.privacyPolicyUrl != "" %}
          <li class="hover:underline after:absolute after:content-['|'] after:scale-150 relative before:content-[' '] after:left-[-11px] after:text-lg">
            <a
              data-umami-event="PrivacyPolicy-footer"
              href="{{ site.privacyPolicyUrl }}"
              target="_blank">Privacy Policy</a>
          </li>
        {% endif %}
      </ul>
    </div>
  </form>
  <script>
    (function() {
      var form = document.currentScript.closest('.c-formBuilder').querySelector('form');
      if (!form) return;
      var params = new URLSearchParams(window.location.search);
      if (!params.toString()) return;

      function slugify(str) {
        return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
      }

      var fields = form.querySelectorAll('input, select, textarea');
      params.forEach(function(value, key) {
        var sluggedKey = slugify(decodeURIComponent(key));
        fields.forEach(function(field) {
          if (!field.name) return;
          var sluggedName = slugify(field.name);
          if (sluggedName === sluggedKey) {
            if (field.type === 'checkbox' || field.type === 'radio') {
              if (slugify(field.value) === slugify(decodeURIComponent(value))) {
                field.checked = true;
              }
            } else if (field.tagName === 'SELECT') {
              for (var i = 0; i < field.options.length; i++) {
                if (slugify(field.options[i].value) === slugify(decodeURIComponent(value))) {
                  field.selectedIndex = i;
                  break;
                }
              }
            } else {
              field.value = decodeURIComponent(value);
            }
          }
        });
      });
    })();
  </script>
</div>